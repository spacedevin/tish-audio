import { h, useEffect, useRef } from "lattish"
import { VerticalFader, RotaryKnob, LedMeter } from "./controls.tish"
import { X } from "../icons.tish"

export const hardwareRemoveClass = "z-30 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-zinc-950/90 bg-gradient-to-b from-zinc-200 via-zinc-500 to-zinc-900 text-zinc-950 shadow-[inset_0_1px_0_rgba(255,255,255,0.45),inset_0_-4px_8px_rgba(0,0,0,0.55),0_3px_12px_rgba(0,0,0,0.55)] transition-all duration-200 hover:from-orange-200 hover:via-orange-400 hover:to-orange-950 hover:text-white hover:border-orange-950/80 hover:shadow-[0_0_14px_rgba(249,115,22,0.45)] active:scale-95";

export fn ConsoleNode(props) { let node = props.node; let onRemove = props.onRemove; let onChange = props.onChange; let onDragStart = props.onDragStart; let audioDataMap = props.audioDataMap;
let meterSync = props.meterSync;
let onFaderDragEnd = props.onFaderDragEnd;
let previewOnly = props.previewOnly === true;
const numCh = node.params.channels || 4;
const analysers = audioDataMap[node.id]?.analysers || {};
return (
<div class="relative w-[640px] h-[216px] flex rounded-sm overflow-hidden border border-black shadow-[0_18px_44px_rgba(0,0,0,0.92)] bg-zinc-950 transition-all duration-300 select-none touch-none">
<div class="absolute inset-0 pointer-events-none opacity-[0.18]" style={{ filter: 'url(#metal-texture)' }} />

{!previewOnly && onDragStart ? (
<div
onPointerDown={(e) => { if (e.button !== 0) return; e.preventDefault(); onDragStart(e); }}
class="absolute inset-0 z-[6] rounded-sm cursor-grab active:cursor-grabbing touch-none"
/>
) : null}

<div class="relative z-10 w-6 shrink-0 flex flex-col items-center justify-between py-3 px-0.5 bg-gradient-to-b from-zinc-500 via-zinc-700 to-zinc-900 border-r border-black/70 pointer-events-none">
<div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-zinc-400 to-zinc-900 border border-black/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]" />
<div class="flex flex-col gap-0.5 w-4 py-1">
<div class="h-px bg-black/50 rounded-full" />
<div class="h-px bg-zinc-500/40 rounded-full" />
<div class="h-px bg-black/50 rounded-full" />
<div class="h-px bg-zinc-500/40 rounded-full" />
</div>
<div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-zinc-400 to-zinc-900 border border-black/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]" />
</div>

<div class="relative z-10 flex-1 flex flex-col min-w-0 bg-gradient-to-b from-zinc-800 via-zinc-900 to-black border-l border-r border-zinc-950/80">
{!previewOnly && onDragStart ? (
<div
onPointerDown={(e) => { if (e.button !== 0) return; e.preventDefault(); onDragStart(e); }}
class="absolute inset-0 z-[6] cursor-grab active:cursor-grabbing touch-none"
/>
) : null}

<div class={"relative z-10 h-1 shrink-0 w-full bg-gradient-to-r " + node.color} />

<div class="relative z-10 flex justify-between items-center gap-2 px-2 py-1.5 border-b border-black/55 bg-black/35 shrink-0 pointer-events-none">
<div class="flex flex-col min-w-0 flex-1">
<span class="text-[8px] font-black tracking-[0.2em] text-zinc-500 uppercase">Rack · mixer</span>
<div class="text-sm font-black tracking-widest uppercase truncate text-white drop-shadow-md">
{node.label}
</div>
</div>
<div class="flex items-center gap-2 shrink-0 pointer-events-auto">
{!previewOnly ? (
<div class="flex items-center gap-1 bg-black/50 border border-zinc-800 rounded px-1 py-0.5 shadow-[inset_0_1px_3px_rgba(0,0,0,0.6)]">
<button type="button" onClick={(e) => { e.stopPropagation(); onChange('channels', Math.max(1, numCh - 1)); }} class="text-zinc-500 hover:text-white text-[10px] font-bold px-0.5 leading-none" title="Fewer channels">−</button>
<span class="text-[8px] font-bold text-orange-500 w-6 text-center font-mono tabular-nums">{numCh}</span>
<button type="button" onClick={(e) => { e.stopPropagation(); onChange('channels', Math.min(16, numCh + 1)); }} class="text-zinc-500 hover:text-white text-[10px] font-bold px-0.5 leading-none" title="More channels">+</button>
</div>
) : null}
{!previewOnly ? (
<button type="button" title="Remove mixer" onPointerDown={(e) => { if (e.button !== 0) return; e.stopPropagation(); e.preventDefault(); onRemove(); }} onKeyDown={(e) => { if (e.key !== 'Enter' && e.key !== ' ') return; e.preventDefault(); e.stopPropagation(); onRemove(); }} class={hardwareRemoveClass}>
<X class="w-4 h-4" />
</button>
) : null}
</div>
</div>

<div class={"relative z-10 flex flex-1 min-h-0 min-w-0 flex-row gap-1 px-1 py-1 items-stretch " + (previewOnly ? "pointer-events-none opacity-80" : "pointer-events-none")}>
<div class="flex-1 min-w-0 overflow-x-auto overflow-y-hidden flex flex-row gap-0.5 items-stretch justify-start pointer-events-none" style={{ overscrollBehaviorX: 'contain' }}>
{Array.from({length: numCh}).map((_, i) => {
const key = "ch" + String(i + 1);
return (
<VerticalFader key={key} rackSlot={true} heightClass="h-24" meterSync={meterSync} onFaderDragEnd={onFaderDragEnd} label={String(i + 1)} min={0} max={2} value={node.params[key] ?? 1.0} onChange={(v) => onChange(key, v)} analyser={analysers[key]} interactive={!previewOnly} />
);
})}
</div>
<div class="w-px self-stretch bg-zinc-800 mx-0.5 border-r border-zinc-950/50 shrink-0" />
<VerticalFader rackSlot={true} heightClass="h-24" meterSync={meterSync} onFaderDragEnd={onFaderDragEnd} label="MSTR" min={0} max={2} value={node.params.master ?? 1.0} onChange={(v) => onChange('master', v)} analyser={analysers.master} variant="master" interactive={!previewOnly} />
</div>
</div>

<div class="relative z-10 w-6 shrink-0 flex flex-col items-center justify-between py-3 px-0.5 bg-gradient-to-b from-zinc-500 via-zinc-700 to-zinc-900 border-l border-black/70 pointer-events-none">
<div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-zinc-400 to-zinc-900 border border-black/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]" />
<div class="flex flex-col gap-0.5 w-4 py-1">
<div class="h-px bg-black/50 rounded-full" />
<div class="h-px bg-zinc-500/40 rounded-full" />
<div class="h-px bg-black/50 rounded-full" />
<div class="h-px bg-zinc-500/40 rounded-full" />
</div>
<div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-zinc-400 to-zinc-900 border border-black/80 shadow-[inset_0_1px_1px_rgba(255,255,255,0.2)]" />
</div>
</div>
);
}

export fn GraphicEqNode(props) { let node = props.node; let onRemove = props.onRemove; let onChange = props.onChange; let onDragStart = props.onDragStart; let onToggleBypass = props.onToggleBypass; let audioDataMap = props.audioDataMap;
let meterSync = props.meterSync;
