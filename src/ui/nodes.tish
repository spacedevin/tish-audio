const masterAnalyser = audioDataMap[node.id]?.analyser;
const bands = [31, 62, 125, 250, 500, '1k', '2k', '4k', '8k', '16k'];

return (
<div class={"relative w-[640px] h-[216px] flex rounded-sm overflow-hidden border border-black shadow-[0_18px_44px_rgba(0,0,0,0.92)] bg-zinc-950 transition-all duration-300 select-none touch-none " + (isBypassed ? "brightness-50 grayscale opacity-80" : "brightness-100 grayscale-0 opacity-100")}>
<div class="absolute inset-0 pointer-events-none opacity-[0.2]" style={{ filter: 'url(#metal-texture)' }} />

