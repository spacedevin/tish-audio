export const PEDAL_LIBRARY = { ...LEGACY_LIBRARY };

/** SMK-25 layout: encoder interface outputs ctrl1–ctrl16 (not audio; 9–16 = KNOB-B layer). */
export fn isSmkControlOutputPort(portId) {
  const s = String(portId || "");
  if (s.length < 5 || s.slice(0, 4) !== "ctrl") {
    return false;
  }
  const n = parseInt(s.slice(4), 10);
  return Number.isFinite(n) && n >= 1 && n <= 16;
}

export fn isControlInputPort(portId) {
  return portId === "ctrl";
}

const MODULES_WITHOUT_AUTO_CONTROL_PORTS = {
  smk25_face: true,
  midi_recorder: true,
  midi_poly: true,
  midi_channel_splitter: true,
  midi_semantic_splitter: true,
  pad_micro: true,
  analog_poly_juniper: true,
  fm_4op: true,
  hybrid_toxic_x: true,
  wavetable_morph: true,
  organ_drawbars: true,
  drum_machine_xr: true,
  rompler_90s: true,
  vocoder_pad: true,
  analog_mono_lead: true
};

export fn getNodeControlPorts(node) {
  if (!node || !node["type"] || MODULES_WITHOUT_AUTO_CONTROL_PORTS[node["type"]] === true) {
    return [];
  }
  if (node["type"] === "console_mixer") {
    const p = node.params || {};
    const ch = Number.isFinite(p.channels) ? p.channels : 4;
    const out = [];
    let i = 1;
    while (i <= ch) {
      out.push({ portId: "ch" + String(i), paramKey: "ch" + String(i), min: 0, max: 1, accepts: "any" });
      i = i + 1;
    }
    out.push({ portId: "master", paramKey: "master", min: 0, max: 1, accepts: "any" });
    return out;
  }
  const reg = MODULE_REGISTRY[node["type"]];
  const dp = reg && reg.metadata && reg.metadata.defaultParams ? reg.metadata.defaultParams : null;
  let sourceParams = dp;
  if ((!sourceParams || typeof sourceParams !== "object") && node.params && typeof node.params === "object") {
    sourceParams = node.params;
  }
  if (!sourceParams || typeof sourceParams !== "object") {
    return [];
  }
  const keys = Object.keys(sourceParams);
  const out = [];
  let i = 0;
  while (i < keys.length) {
    const k = keys[i];
    if (k !== "uiForm" && k !== "channels") {
      const range = controlParamRangeForKey(node["type"], k);
      out.push({ portId: k, paramKey: k, min: range.min, max: range.max, accepts: "any" });
    }
    i = i + 1;
  }
  return out;
}

/** SMK-25 layout: three logical MIDI inputs (device USB endpoints → separate patch jacks). */
export fn isSmk25FaceMidiInputPort(portId) {
  return portId === "midi1" || portId === "midi2" || portId === "midi3";
}

export fn isSmk25FaceMidiOutputPort(portId) {
  return portId === "keys" || portId === "pads" || portId === "knobs";
}

export fn isMidiChannelSplitterOutputPort(portId) {
  const s = String(portId || "");
  if (s.length < 3 || s.slice(0, 2) !== "ch") {
    return false;
  }
  const n = parseInt(s.slice(2), 10);
  return Number.isFinite(n) && n >= 1 && n <= 16;
}

export fn isSemanticMidiPort(portId) {
  const p = String(portId || "");
  if (p.slice(0, 4) === "knob") {
    const n = parseInt(p.slice(4), 10);
    if (Number.isFinite(n) && n >= 1 && n <= 16) {
      return true;
    }
  }
  return (
    p === "pitch" ||
    p === "mode" ||
    p === "play" ||
    p === "stop" ||
    p === "rec"
  );
}

/** midi1…midi8 — combo MIDI_IN outs or other multi-leg MIDI edges (never Web Audio). */
export fn isComboStyleMidiPort(portId) {
  const s = String(portId || "");
  if (s.length < 5 || s.slice(0, 4) !== "midi") {
    return false;
  }
  const n = parseInt(s.slice(4), 10);
  return Number.isFinite(n) && n >= 1 && n <= 8;
}

export fn isMidiGraphPortId(portId) {
  return (
    portId === "midi" ||
    isSmk25FaceMidiInputPort(portId) ||
    isSmk25FaceMidiOutputPort(portId) ||
    isSemanticMidiPort(portId) ||
    isMidiChannelSplitterOutputPort(portId) ||
    isComboStyleMidiPort(portId)
  );
}

export fn getMidiInOutPortIds(node) {
  if (!node || node["type"] !== "MIDI_IN") {
    return ["midi"];
  }
  const p = node.params;
  if (p && p.midiComboLayout === "smk25" && p.midiInputIds && p.midiInputIds.length) {
    const o = [];
    let j = 0;
    const cap = p.midiInputIds.length < 8 ? p.midiInputIds.length : 8;
    while (j < cap) {
      o.push("midi" + String(j + 1));
      j = j + 1;
    }
    return o;
  }
  return ["midi"];
}

/** First mapped param for a new SMK ctrl→pedal wire (prefers `mix` when present in module defaults). */
export fn defaultCtrlParamKeyForModuleType(moduleType) {
  const meta = MODULE_REGISTRY[moduleType] && MODULE_REGISTRY[moduleType].metadata;
  const dp = meta && meta.defaultParams;
  if (!dp || typeof dp !== "object") {
    return "mix";
  }
  if (Object.prototype.hasOwnProperty.call(dp, "mix")) {
    return "mix";
  }
  const keys = Object.keys(dp);
  if (keys.length) {
    return keys[0];
  }
  return "mix";
}

/** UI knob min/max for SMK ctrl→param mapping (matches RotaryKnob ranges on each module). */
export fn controlParamRangeForKey(moduleType, paramKey) {
  const key = String(paramKey || "");
  const t = String(moduleType || "");
  if (t === "delay") {
    if (key === "time") {
      return { min: 0, max: 8 };
    }
    if (key === "feedback" || key === "mix") {
      return { min: 0, max: 1 };
    }
  }
  if (t === "compressor") {
    if (key === "threshold") {
      return { min: -60, max: 0 };
    }
    if (key === "ratio") {
      return { min: 1, max: 20 };
    }
    if (key === "makeup") {
      return { min: 0, max: 5 };
    }
  }
  if (t === "muff") {
    if (key === "drive") {
      return { min: 0, max: 1000 };
    }
    if (key === "tone") {
      return { min: 100, max: 5000 };
    }
    if (key === "level") {
      return { min: 0, max: 1 };
    }
  }
  if (t === "hall_verb" || t === "plate_verb" || t === "spring_verb") {
    if (key === "mix") {
      return { min: 0, max: 1 };
    }
    if (key === "decay") {
      return { min: 0, max: 8 };
    }
  }
  if (t === "shimmer_verb") {
    if (key === "mix" || key === "sheen") {
      return { min: 0, max: 1 };
    }
    if (key === "decay") {
      return { min: 0, max: 8 };
    }
  }
  if (t === "overdrive" || t === "screamer" || t === "blues_od" || t === "ds1" || t === "fuzz" || t === "octa_fuzz") {
    if (key === "drive") return { min: 0, max: 1000 };
    if (key === "tone" || key === "filter") return { min: 100, max: 5000 };
    if (key === "level") return { min: 0, max: 1 };
  }
  if (t === "rat") {
    if (key === "drive") return { min: 0, max: 1000 };
    if (key === "filter") return { min: 100, max: 5000 };
    if (key === "level") return { min: 0, max: 1 };
  }
  if (t === "metal") {
    if (key === "drive") return { min: 0, max: 1000 };
    if (key === "midFreq") return { min: 100, max: 3000 };
    if (key === "midCut") return { min: -24, max: 12 };
    if (key === "level") return { min: 0, max: 1 };
  }
  if (t === "centaur") {
    if (key === "drive") return { min: 0, max: 1000 };
    if (key === "highs") return { min: 0, max: 10 };
    if (key === "output") return { min: 0, max: 1 };
  }
  if (t === "amp_tweed" || t === "amp_stack" || t === "amp_modern") {
    if (key === "gain") return { min: 0, max: 100 };
    if (key === "bass" || key === "mid" || key === "treble") return { min: 0, max: 2 };
    if (key === "presence") return { min: 500, max: 8000 };
    if (key === "master") return { min: 0, max: 1 };
  }
  if (t === "chorus") {
    if (key === "rate") return { min: 0.1, max: 10 };
    if (key === "depth") return { min: 0, max: 1 };
  }
  if (t === "flanger") {
    if (key === "rate") return { min: 0.1, max: 5 };
    if (key === "depth") return { min: 0, max: 0.02 };
    if (key === "feedback") return { min: 0, max: 0.95 };
  }
  if (t === "vibrato") {
    if (key === "rate") return { min: 0.1, max: 10 };
    if (key === "depth") return { min: 0, max: 0.01 };
  }
  if (t === "rotary") {
    if (key === "rate") return { min: 0.1, max: 12 };
    if (key === "mix") return { min: 0, max: 1 };
  }
  if (t === "phaser") {
    if (key === "rate") return { min: 0.1, max: 10 };
    if (key === "sweep") return { min: 100, max: 2000 };
  }
  if (t === "auto_wah" || t === "tron") {
    if (key === "rate") return { min: 0.1, max: 12 };
    if (key === "sweep") return { min: 100, max: 4000 };
    if (key === "baseFreq") return { min: 80, max: 2000 };
  }
  if (t === "eq7") {
    if (key === "level") return { min: 0, max: 2 };
    if (key.slice(0, 1) === "b") return { min: -18, max: 18 };
  }
  if (t === "console_mixer") {
    if (key === "master" || key.slice(0, 2) === "ch") return { min: 0, max: 1 };
  }
  if (t === "master_eq") {
    if (key === "level") return { min: 0, max: 2 };
    if (key === "sub" || key === "low" || key === "mid" || key === "high" || key === "air") return { min: -1, max: 1 };
  }
  if (t === "graphic_eq") {
    if (key === "level") return { min: 0, max: 2 };
    if (key.slice(0, 1) === "b") return { min: -1, max: 1 };
  }
  if (t === "midi_poly") {
    if (key === "level") return { min: 0, max: 1 };
    if (key === "waveform") return { min: 0, max: 3 };
    if (key === "brightness") return { min: 0, max: 1 };
  }
  if (t === "pad_micro" || t === "analog_poly_juniper" || t === "fm_4op" || t === "hybrid_toxic_x" || t === "wavetable_morph" || t === "organ_drawbars" || t === "drum_machine_xr" || t === "rompler_90s" || t === "vocoder_pad" || t === "analog_mono_lead") {
    if (key === "level" || key === "tone" || key === "motion") return { min: 0, max: 1 };
  }
  if (key === "time") return { min: 0, max: 8 };
  if (key === "threshold") return { min: -60, max: 0 };
  if (key === "ratio") return { min: 1, max: 20 };
  if (key === "makeup") return { min: 0, max: 8 };
  if (key === "mix" || key === "feedback" || key === "depth" || key === "spread" || key === "sheen" || key === "age") return { min: 0, max: 1 };
  if (key === "drive" || key === "gain") return { min: 0, max: 1000 };
  if (key.indexOf("freq") >= 0 || key.indexOf("Freq") >= 0 || key === "tone" || key === "filter" || key === "cut" || key === "dark" || key === "presence" || key === "sweep" || key === "baseFreq") {
    return { min: 80, max: 8000 };
  }
  if (key === "level" || key === "output" || key === "master") return { min: 0, max: 1 };
  if (key.slice(0, 1) === "b") return { min: -1, max: 1 };
  return { min: 0, max: 1 };
}

const SMK25_FACE_OUT_PORTS = [
  "keys",
  "pads",
  "knobs"
];

const MIDI_CHANNEL_SPLITTER_OUT_PORTS = [
  "ch1", "ch2", "ch3", "ch4",
  "ch5", "ch6", "ch7", "ch8",
  "ch9", "ch10", "ch11", "ch12",
  "ch13", "ch14", "ch15", "ch16"
];
const MIDI_SEMANTIC_SPLITTER_OUT_PORTS = [
  "knob1", "knob2", "knob3", "knob4", "knob5", "knob6", "knob7", "knob8",
  "knob9", "knob10", "knob11", "knob12", "knob13", "knob14", "knob15", "knob16",
  "play", "stop", "rec", "pitch", "mode"
];

export const getNodePorts = (node) => {
  if (!node) return { "in": ['main'], "out": ['main'] };
  if (node["type"] === 'MIDI_IN') return { "in": [], "out": getMidiInOutPortIds(node) };
  if (node["type"] === 'SYS_IN') return { "in": ['main'], "out": ['main'] };
  if (node["type"] === 'midi_recorder') return { "in": ['midi'], "out": ['midi'] };
  if (node["type"] === 'midi_channel_splitter') return { "in": ['midi'], "out": MIDI_CHANNEL_SPLITTER_OUT_PORTS };
  if (node["type"] === 'midi_semantic_splitter') return { "in": ['midi'], "out": MIDI_SEMANTIC_SPLITTER_OUT_PORTS };
  if (node["type"] === 'smk25_face') {
    return { "in": ['midi1', 'midi2', 'midi3'], "out": SMK25_FACE_OUT_PORTS };
  }
  if (node["type"] === 'midi_poly') return { "in": ['midi'], "out": ['main'] };
  if (node["type"] === 'pad_micro' || node["type"] === 'analog_poly_juniper' || node["type"] === 'fm_4op' || node["type"] === 'hybrid_toxic_x' || node["type"] === 'wavetable_morph' || node["type"] === 'organ_drawbars' || node["type"] === 'drum_machine_xr' || node["type"] === 'rompler_90s' || node["type"] === 'vocoder_pad' || node["type"] === 'analog_mono_lead') return { "in": ['midi', 'main'], "out": ['main'] };
  const regAccept = MODULE_REGISTRY[node["type"]];
  if (regAccept && regAccept.acceptsMidiInput === true) {
    return { "in": ['midi', 'main'], "out": ['main'] };
  }

  if (MODULE_REGISTRY[node["type"]]?.ports) {
    if (typeof MODULE_REGISTRY[node["type"]].ports === 'function') {
      return MODULE_REGISTRY[node["type"]].ports(node);
    }
    return MODULE_REGISTRY[node["type"]].ports;
  }

  // legacy fallback
  if (node["type"] === 'crossover') return { "in": ['main'], "out": ['low', 'high'] };
  if (node["type"] === 'console_mixer') {
    const numCh = node.params.channels || 4;
    const ins = [];
    for(let i=1; i<=numCh; i = i + 1) ins.push("ch" + String(i));
    if (ins.indexOf("master") < 0) {
      ins.push("master");
    }
    return { "in": ins, "out": ['main'] };
  }
  const regMod = MODULE_REGISTRY[node["type"]];
  if (regMod && regMod.acceptsControlInput === true) {
    const ctrlPorts = getNodeControlPorts(node).map((p) => p.portId);
    const ins = ['main', 'ctrl'];
    let i = 0;
    while (i < ctrlPorts.length) {
      if (ins.indexOf(ctrlPorts[i]) < 0) {
        ins.push(ctrlPorts[i]);
      }
      i = i + 1;
    }
    return { "in": ins, "out": ['main'] };
  }
  const autoCtrl = getNodeControlPorts(node).map((p) => p.portId);
  if (autoCtrl.length > 0) {
    const ins = ['main'];
    let i = 0;
    while (i < autoCtrl.length) {
      if (ins.indexOf(autoCtrl[i]) < 0) {
        ins.push(autoCtrl[i]);
      }
      i = i + 1;
    }
    return { "in": ins, "out": ['main'] };
  }
  return { "in": ['main'], "out": ['main'] };
};
