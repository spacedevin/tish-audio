    category: vocoder_pad.vocoder_pad_category,
    metadata: vocoder_pad.vocoder_pad_metadata,
    layout: vocoder_pad.vocoder_pad_layout,
    View: vocoder_pad.vocoder_pad_View,
    buildAudio: vocoder_pad.vocoder_pad_buildAudio,
    acceptsMidiInput: true,
    paintScene: vocoder_pad.vocoder_pad_paintScene,
    inputBindings: vocoder_pad.vocoder_pad_inputBindings,
    parameters: vocoder_pad.vocoder_pad_parameters,
    requirements: vocoder_pad.vocoder_pad_requirements,
  },
  'analog_mono_lead': {
    type: analog_mono_lead.analog_mono_lead_type,
    category: analog_mono_lead.analog_mono_lead_category,
    metadata: analog_mono_lead.analog_mono_lead_metadata,
    layout: analog_mono_lead.analog_mono_lead_layout,
    View: analog_mono_lead.analog_mono_lead_View,
    buildAudio: analog_mono_lead.analog_mono_lead_buildAudio,
    acceptsMidiInput: true,
    paintScene: analog_mono_lead.analog_mono_lead_paintScene,
    inputBindings: analog_mono_lead.analog_mono_lead_inputBindings,
    parameters: analog_mono_lead.analog_mono_lead_parameters,
    requirements: analog_mono_lead.analog_mono_lead_requirements,
  },
};



