/**
 * MultiBank XV-1000 — workstation-class multi-timbral tone module.
 * 256 selectable programs across 16 GM-style categories. Each category drives
 * its own oscillator/filter/envelope recipe so patches actually sound different.
 */
import { h, useState, useEffect, useRef } from "lattish"
import { RackChassis } from "../../../moduleKit/ui/index.tish"
import { RotaryKnob } from "../../../ui/controls.tish"
import { hzFromMidi } from "../../../guitar/instrumentSpec.tish"
import { createVoiceManager } from "../../../audio/synth/voiceManager.tish"
import { applyAdsr, releaseAdsr } from "../../../audio/synth/envelope.tish"
import { createFxBus } from "../../../audio/synth/fxBus.tish"
import { Group, Rect, Text } from "../../../render/prims.tish"
import { lcdPanel, knobOrnate, screwHead } from "../../../render/widgets/materialKit.tish"
import { materialTokens, getEraPalette } from "../../../render/themeTokens.tish"

