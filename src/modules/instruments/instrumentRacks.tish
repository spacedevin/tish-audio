    { id: "knob_level_" + String(n.id), rect: { x: x + 380, y: y + 110, w: 50, h: 60 }, role: "knob", param: "level" },
    { id: "knob_tone_" + String(n.id), rect: { x: x + 430, y: y + 110, w: 50, h: 60 }, role: "knob", param: "tone" },
