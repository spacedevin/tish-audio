export fn wavetableProPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "wt", x: 0, y: 0, label: "Wavetable Pro" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("plasma_blue");
  const lcd = materialTokens.vfd_cyan;
  const children = [];
  const head = rkPaintHeader("wt_" + String(node.id), x, y, RACK_W, palette, "Wavetable Pro", "plasma_blue");
  let i = 0;
  while (i < head.length) { children.push(head[i]); i = i + 1; }
  children.push(Rect("wt_window_" + String(node.id), x + 22, y + 56, 200, 70, { fill: "#03161c", stroke: lcd.fg, strokeWidth: 1, radius: 3 }));
  children.push(Path("wt_wave_" + String(node.id), "M " + String(x + 26) + " " + String(y + 92) + " Q " + String(x + 80) + " " + String(y + 64) + " " + String(x + 130) + " " + String(y + 92) + " Q " + String(x + 180) + " " + String(y + 122) + " " + String(x + 220) + " " + String(y + 92), { stroke: lcd.fg, strokeWidth: 2 }));
  children.push(Rect("wt_xy_" + String(node.id), x + 240, y + 56, 110, 110, { fill: "#000000", stroke: lcd.fg, strokeWidth: 2, radius: 4 }));
  let r = 0;
  while (r < 4) {
    const rad = 14 + r * 8;
    children.push(Rect("wt_ring_" + String(r) + "_" + String(node.id), x + 410 - rad, y + 100 - rad, rad * 2, rad * 2, { fill: null, stroke: lcd.fg, strokeWidth: 1, radius: rad, opacity: 0.5 }));
    r = r + 1;
  }
  const knobs = rkKnobRow("wt_knobs_" + String(node.id), x + 480, y + 130, 3, palette);
  let ki = 0;
  while (ki < knobs.length) { children.push(knobs[ki]); ki = ki + 1; }
  return { resources: [], primitives: [Group("wt_root_" + String(node.id), children, {})] };
}

export fn wavetableProInputBindings(ctx) {
  const n = (ctx && ctx.node) ? ctx.node : { id: "wt", x: 0, y: 0 };
