export fn vocoderPadPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "voc", x: 0, y: 0, label: "Vocoder Pad" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("industrial_grey");
  const children = [];
  children.push(Rect("voc_panel_" + String(node.id), x, y, RACK_W, RACK_H, { fill: "#0a0a0a", stroke: "#000000", strokeWidth: 2, radius: 6 }));
  children.push(Text("voc_title_" + String(node.id), x + 18, y + 28, "Vocoder · MK-VII", { color: palette.text, size: 16, weight: 900 }));
  children.push(mat.perforatedGrille("voc_grille_" + String(node.id), x + 22, y + 56, 130, 110, palette));
  let r = 0;
  while (r < 5) {
    const rad = 18 + r * 8;
    children.push(Rect("voc_ring_" + String(r) + "_" + String(node.id), x + 240 - rad, y + 110 - rad, rad * 2, rad * 2, { fill: null, stroke: palette.text, strokeWidth: 1, radius: rad, opacity: 0.5 }));
    r = r + 1;
  }
  let v = 0;
  while (v < 6) {
    children.push(mat.vuMeterStrip("voc_vu_" + String(v) + "_" + String(node.id), x + 320 + v * 22, y + 60, 14, 110, 0.4 + (v % 3) * 0.18, { on: "#f8fafc", off: "#1f2937" }));
    v = v + 1;
  }
  const knobs = rkKnobRow("voc_knobs_" + String(node.id), x + 480, y + 130, 3, palette);
  let ki = 0;
  while (ki < knobs.length) { children.push(knobs[ki]); ki = ki + 1; }
  return { resources: [], primitives: [Group("voc_root_" + String(node.id), children, {})] };
}

