export fn organDrawbarsPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "org", x: 0, y: 0, label: "Organ Drawbars" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("tonewheel_walnut");
  const children = [];
  children.push(Rect("org_panel_" + String(node.id), x, y, RACK_W, RACK_H, { fill: "#3a2418", stroke: "#1a120e", strokeWidth: 2, radius: 6 }));
  children.push(Text("org_title_" + String(node.id), x + 18, y + 28, "Drawbar Organ", { color: palette.text, size: 16, weight: 900 }));
  const drawbarColors = ["#fafaf9", "#fafaf9", "#a8a29e", "#fafaf9", "#a8a29e", "#fafaf9", "#a8a29e", "#92400e", "#92400e"];
  let d = 0;
  while (d < 9) {
    children.push(mat.drawbar("org_db_" + String(d) + "_" + String(node.id), x + 22 + d * 22, y + 50, 14, 130, 0.7 - d * 0.08, drawbarColors[d]));
    d = d + 1;
  }
  children.push(mat.lcdPanel("org_lcd_" + String(node.id), x + 240, y + 52, 160, 36, "PERC · LESLIE", materialTokens.lcd_amber));
  children.push(mat.jewelLed("org_perc_" + String(node.id), x + 260, y + 110, 4, "#fbbf24", true));
  children.push(mat.jewelLed("org_lesl_" + String(node.id), x + 290, y + 110, 4, "#22c55e", true));
  const knobs = rkKnobRow("org_knobs_" + String(node.id), x + 460, y + 130, 3, palette);
  let ki = 0;
  while (ki < knobs.length) { children.push(knobs[ki]); ki = ki + 1; }
  return { resources: [], primitives: [Group("org_root_" + String(node.id), children, {})] };
}

export fn organDrawbarsInputBindings(ctx) {
  const n = (ctx && ctx.node) ? ctx.node : { id: "org", x: 0, y: 0 };
  const x = Number(n.x) || 0;
