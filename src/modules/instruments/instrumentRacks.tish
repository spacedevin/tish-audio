  ];
}

export fn drumXrPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "dr", x: 0, y: 0, label: "Drum XR" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("tan_red_drum");
  const children = [];
  children.push(Rect("dr_panel_" + String(node.id), x, y, RACK_W, RACK_H, { fill: "#3f2a1a", stroke: "#1a120e", strokeWidth: 2, radius: 6 }));
  children.push(Text("dr_title_" + String(node.id), x + 18, y + 28, "Drum Machine XR", { color: palette.text, size: 16, weight: 900 }));
  let pi = 0;
  while (pi < 8) {
    const px = x + 24 + (pi % 4) * 50;
    const py = y + 50 + Math.floor(pi / 4) * 50;
    children.push(mat.padCell("dr_pad_" + String(pi) + "_" + String(node.id), px, py, 44, 44, pi === 0, "#b91c1c"));
    pi = pi + 1;
  }
  let s = 0;
  while (s < 16) {
    children.push(mat.jewelLed("dr_step_" + String(s) + "_" + String(node.id), x + 230 + s * 14, y + 80, 4, "#facc15", s === 4));
    s = s + 1;
  }
  children.push(mat.lcdPanel("dr_lcd_" + String(node.id), x + 220, y + 110, 240, 36, "KIT 01 · 16-STEP · BPM 120", materialTokens.lcd_amber));
  const knobs = rkKnobRow("dr_knobs_" + String(node.id), x + 480, y + 60, 3, palette);
  let ki = 0;
  while (ki < knobs.length) { children.push(knobs[ki]); ki = ki + 1; }
  return { resources: [], primitives: [Group("dr_root_" + String(node.id), children, {})] };
}

export fn drumXrInputBindings(ctx) {
  const n = (ctx && ctx.node) ? ctx.node : { id: "dr", x: 0, y: 0 };
  const x = Number(n.x) || 0;
  const y = Number(n.y) || 0;
  return [
    { id: "knob_level_" + String(n.id), rect: { x: x + 480, y: y + 40, w: 50, h: 60 }, role: "knob", param: "level" },
    { id: "knob_tone_" + String(n.id), rect: { x: x + 530, y: y + 40, w: 50, h: 60 }, role: "knob", param: "tone" },
    { id: "knob_motion_" + String(n.id), rect: { x: x + 580, y: y + 40, w: 50, h: 60 }, role: "knob", param: "motion" }
  ];
}

export fn rompler90sPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "rom", x: 0, y: 0, label: "Rompler 90s" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("nineties_rackmount_blue");
  const children = [];
  children.push(Rect("rom_panel_" + String(node.id), x, y, RACK_W, RACK_H, { fill: "#0c1a30", stroke: "#000000", strokeWidth: 2, radius: 6 }));
  children.push(Rect("rom_ear_l_" + String(node.id), x, y, 26, RACK_H, { fill: "#1e3a5f", stroke: "#000000", strokeWidth: 1, radius: 4 }));
  children.push(Rect("rom_ear_r_" + String(node.id), x + RACK_W - 26, y, 26, RACK_H, { fill: "#1e3a5f", stroke: "#000000", strokeWidth: 1, radius: 4 }));
  children.push(mat.screwHead("rom_sl1_" + String(node.id), x + 13, y + 24, 4));
  children.push(mat.screwHead("rom_sl2_" + String(node.id), x + 13, y + RACK_H - 24, 4));
  children.push(mat.screwHead("rom_sr1_" + String(node.id), x + RACK_W - 13, y + 24, 4));
  children.push(mat.screwHead("rom_sr2_" + String(node.id), x + RACK_W - 13, y + RACK_H - 24, 4));
  children.push(Text("rom_title_" + String(node.id), x + 40, y + 28, "Rompler · 1U", { color: palette.text, size: 14, weight: 800 }));
  children.push(mat.lcdPanel("rom_lcd_" + String(node.id), x + 38, y + 56, 320, 96, "P012 · GRAND PIANO", { bg: "#031227", fg: "#bfdbfe", glow: 0.4 }));
  children.push(mat.knobOrnate("rom_enc_" + String(node.id), x + 470, y + 100, 56, 0.5, { rim: "#1e3a5f", top: "#bfdbfe" }));
  return { resources: [], primitives: [Group("rom_root_" + String(node.id), children, {})] };
}

