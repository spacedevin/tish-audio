export fn padMicroPaintScene(ctx) {
  const c = ctx || {};
  const node = c.node || { id: "pad", x: 0, y: 0, label: "Pad Micro" };
  const x = Number(node.x) || 0;
  const y = Number(node.y) || 0;
  const palette = getEraPalette("acrylic_glass");
  const children = [];
  children.push(Rect("pad_panel_" + String(node.id), x, y, RACK_W, RACK_H, { fill: "#0f172a", stroke: palette.accent, strokeWidth: 1, radius: 8, opacity: 0.95 }));
  children.push(Rect("pad_glow_" + String(node.id), x + 4, y + 4, RACK_W - 8, RACK_H - 8, { fill: palette.accent, opacity: 0.06, radius: 6 }));
  children.push(Text("pad_title_" + String(node.id), x + 24, y + 28, "Pad Micro · Acrylic", { color: palette.text, size: 14, weight: 800 }));
  const cx = x + RACK_W * 0.5;
  const cy = y + RACK_H * 0.55;
  let ring = 0;
  while (ring < 3) {
    const rr = 50 + ring * 14;
    children.push(Rect("pad_ring_" + String(ring) + "_" + String(node.id), cx - rr, cy - rr, rr * 2, rr * 2, { fill: null, stroke: palette.glow, strokeWidth: 1, radius: rr, opacity: 0.35 - ring * 0.08 }));
    ring = ring + 1;
  }
  children.push(mat.knobOrnate("pad_halo_" + String(node.id), cx, cy, 60, 0.5, { rim: "#0c4a6e", top: "#38bdf8" }));
  return { resources: [], primitives: [Group("pad_root_" + String(node.id), children, {})] };
}

export fn padMicroInputBindings(ctx) {
  const n = (ctx && ctx.node) ? ctx.node : { id: "pad", x: 0, y: 0 };
  const x = Number(n.x) || 0;
  const y = Number(n.y) || 0;
  return [
    { id: "knob_level_" + String(n.id), rect: { x: x + RACK_W * 0.5 - 36, y: y + RACK_H * 0.55 - 36, w: 72, h: 72 }, role: "knob", param: "level" }
  ];
}

