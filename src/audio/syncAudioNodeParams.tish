export fn syncAudioNodeParams(ctx, mapRef, nodes) {
if (!ctx || !mapRef || !mapRef.current || !nodes) return;
let i = 0;
while (i < nodes.length) {
const node = nodes[i];
if (!node) { i = i + 1; continue; }
const box = mapRef.current[node.id];
if (box && box._syncLiveParams) box._syncLiveParams(ctx, node);
i = i + 1;
}
}
