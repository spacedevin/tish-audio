strumRequired: true,
minHz: 70,
maxHz: 1200,
pitchMode: 'highway',
rootMidi: 60,
holdTailMs: 0
},
rockBand: {
id: 'rockBand',
label: 'Band Party',
subtitle: 'Easier timing, 4 columns',
playerHint: 'Same as columns + yellow line, but you do not need an extra strum. Gems are a bit taller so timing is more forgiving.',
laneCount: 4,
laneColors: ['#f97316', '#06b6d4', '#eab308', '#ec4899'],
scrollPxPerMs: 0.34,
hitWindowPx: 36,
missPastPx: 62,
spawnIntervalMs: 950,
