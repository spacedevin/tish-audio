playerHint: 'Six narrow columns; the set of notes shifts gently with your playing so frets feel wider. Still match gem column to orange box at the yellow line.',
laneCount: 6,
laneColors: ['#78716c', '#dc2626', '#ea580c', '#ca8a04', '#16a34a', '#2563eb'],
