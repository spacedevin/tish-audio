// Declarative rhythm-game presets (Guitar Hero / Rock Band / Rocksmith–inspired).

export const ARCADE_PROFILE_IDS = ['guitarHero', 'rockBand', 'rocksmith'];

export const ARCADE_PROFILES = {
guitarHero: {
id: 'guitarHero',
label: 'Highway Hero',
subtitle: 'Strum + pitch, 5 columns',
playerHint: 'Orange box = your pitch. Put it in the same colored column as the gem when the gem hits the yellow line. Also give a quick louder strum on the hit.',
laneCount: 5,
laneColors: ['#22c55e', '#ef4444', '#eab308', '#3b82f6', '#a855f7'],
scrollPxPerMs: 0.42,
hitWindowPx: 26,
missPastPx: 55,
