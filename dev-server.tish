import { serve } from "http"
import { readFile, fileExists } from "fs"
import { process } from "process"

// `serve` does not await Promises — the handler must return { status, headers?, body? } synchronously.

fn normalizeRequestPath(raw) {
  let p = raw
  if (typeof p !== "string") {
    return "/"
  }
  let q = p.indexOf("?")
  if (q >= 0) {
    p = p.slice(0, q)
  }
  if (p.startsWith("http://") || p.startsWith("https://")) {
    let sep = p.indexOf("://")
    if (sep >= 0) {
      let pathStart = p.indexOf("/", sep + 3)
      if (pathStart >= 0) {
        p = p.slice(pathStart)
      } else {
        p = "/"
      }
    }
  }
  if (p === "") {
    p = "/"
  }
  while (p.length > 1 && p.endsWith("/")) {
    p = p.slice(0, -1)
  }
  return p
}

fn handleRequest(req) {
  let path = normalizeRequestPath(req.path)
  if (path.indexOf("..") >= 0) {
    return { status: 404, body: "Not Found" }
  }
  if (path === "/") {
    path = "/index.html"
  }

  let targetPath = "dist" + path

  if (fileExists(targetPath)) {
    let body = readFile(targetPath)
    if (typeof body === "string" && body.startsWith("Error:")) {
      return { status: 500, body: body }
    }

    let contentType = "text/plain; charset=utf-8"
    if (path.indexOf(".html") !== -1) {
      contentType = "text/html; charset=utf-8"
    } else if (path.indexOf(".js") !== -1) {
      contentType = "application/javascript; charset=utf-8"
    } else if (path.indexOf(".css") !== -1) {
      contentType = "text/css; charset=utf-8"
    } else if (path.indexOf(".svg") !== -1) {
      contentType = "image/svg+xml"
    }

    return {
      status: 200,
      headers: { "Content-Type": contentType },
      body: body
    }
  }

  return { status: 404, body: "Not Found" }
}

let port = 8080
if (process !== null && process.env !== null && "PORT" in process.env) {
  port = parseInt(process.env.PORT)
}

console.log("Starting server on http://localhost:" + String(port))
serve(port, handleRequest)
