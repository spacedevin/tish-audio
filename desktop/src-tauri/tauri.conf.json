{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ToneFrame",
  "version": "1.0.0",
  "identifier": "com.tish.audio",
  "build": {
    "beforeDevCommand": "npm --prefix .. run build && npm --prefix .. run dev",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ToneFrame",
        "titleBarStyle": "Overlay",
        "decorations": true,
        "width": 1280,
        "height": 800,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* http: https: ws: wss:",
        "font-src": "'self' https://fonts.gstatic.com data:",
        "img-src": "'self' asset: http://asset.localhost https: http: blob: data:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
